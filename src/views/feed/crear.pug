doctype html
html
  head
    title Crear publicacion

  body
    h1 Nueva publicacion

    form(action='/feed/crear' method='POST' enctype='multipart/form-data')
      input(
        type='text'
        name='titulo'
        placeholder='Titulo'
      )

      br

      textarea(
        name='descripcion'
        placeholder='Descripcion'
      )

      br
      br

      label Etiquetas 

      input(
        type='text'
        name='etiquetas'
        placeholder='paisaje,naturaleza,atardecer'
      )

      br

      input(
        type='file'
        name='imagenes'
        multiple
      )

      br

      button(type='submit') Publicar

      br
      br

      label Licencia

      select(name='licencia')
        option(value='copyright') Con copyright
        option(value='sin-copyright') Sin copyright

      br
      br

      label Aplicar marca de agua

      input(
        type='checkbox'
        name='marcaAgua'
       )

      br

      input(
        type='text'
        name='textoMarcaAgua'
        placeholder='Texto de marca de agua'
      )