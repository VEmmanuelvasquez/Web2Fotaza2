doctype html
html
head
title Feed
link(rel='stylesheet' href='/css/style.css')

body

header.navbar
  h1 Fotaza

  .menu

    a(href='/feed') Inicio

    if usuario
      a(href='/feed/crear') Crear publicación
      a(href='/feed/siguiendo') Siguiendo
      a(href='/usuario/perfil') Mi perfil
      a(href='/auth/logout') Logout

      if usuario.rol === 'admin'
        a(href='/admin') 🛠️ Admin

    else
      a(href='/auth/login') Login
      a(href='/auth/register') Registro

.busqueda
  form(action='/feed' method='GET')
    input(
      type='text'
      name='q'
      placeholder='Buscar publicaciones'
      value=busqueda
    )
    button(type='submit') Buscar

.main-feed

  each publicacion in publicaciones

    .card-publicacion

      h2= publicacion.titulo

      p.autor
        b Autor:
        |  #{publicacion.Usuario.nombre}

      p.fecha
        = new Date(publicacion.createdAt).toLocaleString('es-AR')

      p.descripcion= publicacion.descripcion

      if publicacion.listaImagenes.length > 0

        .galeria

          each imagen in publicacion.listaImagenes

            img.foto-publicacion(
             src='/uploads/' + imagen
             onclick=`abrirImagen('/uploads/${imagen}')`
            )

      else if publicacion.mensajeInvitado

        p.aviso
          = publicacion.mensajeInvitado

      .estadisticas

        span ⭐ #{publicacion.promedio}
        span 🗳️ #{publicacion.cantidadVotos}
        span 📄 #{publicacion.licencia}

      if publicacion.Etiqueta && publicacion.Etiqueta.length > 0

        .tags

          each etiqueta in publicacion.Etiqueta

            span.tag
              | ##{etiqueta.nombre}

      if usuario && usuario.id === publicacion.usuarioId

        .acciones

          a(href='/feed/editar/' + publicacion.id)
            button(type='button') Editar

          form(action='/feed/eliminar/' + publicacion.id method='POST')
            button(type='submit') Eliminar

          form(action='/feed/toggle-comentarios/' + publicacion.id method='POST')

            if publicacion.comentariosCerrados
              button(type='submit') 🔓 Abrir comentarios
            else
              button(type='submit') 🔒 Cerrar comentarios

      if usuario

        hr

        if !publicacion.comentariosCerrados

          form(action='/comentarios/crear/' + publicacion.id method='POST')
            input(
              type='text'
              name='texto'
              placeholder='Escribe un comentario'
              required
            )
            button(type='submit') Comentar

        else

          p 🔒 Comentarios cerrados

        form(action='/valoraciones/crear/' + publicacion.id method='POST')
          select(name='puntaje')
            option(value='1') 1
            option(value='2') 2
            option(value='3') 3
            option(value='4') 4
            option(value='5') 5
          button(type='submit') Valorar

      if publicacion.comentarios && publicacion.comentarios.length > 0

        h4 Comentarios

        each comentario in publicacion.comentarios

          .comentario

            p
              b #{comentario.Usuario.nombre}:
              |  #{comentario.texto}

            if usuario && usuario.id !== comentario.usuarioId

              form(
                action='/denuncias-comentarios/crear/' + comentario.id
                method='POST'
              )

                select(name='motivo')
                  option(value='Spam') Spam
                  option(value='Contenido ofensivo') Contenido ofensivo
                  option(value='Acoso') Acoso
                  option(value='Copyright') Copyright

                textarea(
                  name='descripcion'
                  placeholder='Justificación de la denuncia'
                  required
                )

                button(type='submit')
                  | 🚨 Denunciar comentario

      if usuario && usuario.id !== publicacion.usuarioId

        .acciones

          form(action='/intereses/crear/' + publicacion.id method='POST')
            button(type='submit') Me interesa

          form(action='/favoritos/guardar/' + publicacion.id method='POST')
            button(type='submit') ⭐ Favorito

          form(action='/denuncias/crear/' + publicacion.id method='POST')

            select(name='motivo')
              option(value='Spam') Spam
              option(value='Contenido ofensivo') Contenido ofensivo
              option(value='Copyright') Copyright

            input(
              type='text'
              name='descripcion'
              placeholder='Justificación'
              required
            )

            button(type='submit')
              | 🚨 Denunciar

          if colecciones

            form(
              action='/coleccion-publicacion/agregar/' + publicacion.id
              method='POST'
            )

              select(name='coleccionId')

                each coleccion in colecciones

                  option(value=coleccion.id)
                    = coleccion.nombre

              button(type='submit')
                | Agregar a colección
#modalImagen.modal-imagen(onclick='cerrarImagen()')
  img#imagenGrande

          
script.
  function abrirImagen(src){
    document.getElementById('imagenGrande').src = src;
    document.getElementById('modalImagen').style.display = 'flex';
  }

  function cerrarImagen(){
  document.getElementById('modalImagen').style.display = 'none';
  }