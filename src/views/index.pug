doctype html
html
  head
    title fotaza2
    link(rel='stylesheet', href='/css/style.css')
  body
    nav.navbar
      h1.fotaza2 fotaza2
      div.nav-links
        if usuario
          a(href='/feed') Entrar al feed
          a(href='/auth/logout') Logout
        else
          a(href='/auth/login') Login
          a(href='/auth/register') Registro
